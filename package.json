{
  "name": "telegram-notify-bot",
  "version": "1.0.0",
  "description": "Serverless Telegram bot for sending notifications. Deploy with one command to AWS Lambda.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "tofu:init": "cd terraform && tofu init -backend-config=backend.hcl",
    "tofu:plan": "cd terraform && tofu plan",
    "tofu:apply": "cd terraform && tofu apply -auto-approve",
    "tofu:destroy": "cd terraform && tofu destroy -auto-approve",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domengabrovsek/telegram-notify-bot.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "notifications",
    "aws",
    "lambda",
    "serverless",
    "opentofu"
  ],
  "author": "Domen Gabrovšek",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/domengabrovsek/telegram-notify-bot/issues"
  },
  "homepage": "https://github.com/domengabrovsek/telegram-notify-bot#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1021.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
